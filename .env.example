# Knowledge Governance Console does not require secrets by default.
# Keep real credentials out of this file.

# Optional runtime overrides. Values in environment variables take precedence
# over config.yaml, which takes precedence over built-in defaults.
KG_DATA_DIR=data
KG_DATABASE_FILE=knowledge_base.db
KG_PENDING_VERIFY_THRESHOLD=0
KG_SYNC_DIR=sync
KG_LAUNCH_HOST=127.0.0.1
KG_LAUNCH_PORT=8501
KG_LAUNCH_TIMEOUT_SECONDS=30
